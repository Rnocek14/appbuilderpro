# ---- Supabase (required) ----
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ---- AI provider (set on Supabase Edge Function secrets in production) ----
# provider: anthropic | openai | openrouter | local
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
LOCAL_AI_BASE_URL=http://localhost:11434/v1

# ---- Local dev only: call the AI provider directly from the browser ----
# NEVER ship a build with these set. Use edge functions in production.
VITE_AI_DIRECT=false
VITE_AI_PROVIDER=anthropic
VITE_AI_MODEL=claude-sonnet-4-6
VITE_AI_API_KEY=
VITE_LOCAL_AI_BASE_URL=

# ---- Stripe (optional; billing runs in stub mode without these) ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=

# ============================================================================
# EDGE FUNCTION SECRETS (set with `supabase secrets set NAME=value`, NEVER as
# VITE_* — these live server-side only). Each one lights up a pillar; every
# function degrades honestly when its secret is missing. The Health page's
# Master Switch panel shows which of these are actually set right now.
# ============================================================================

# -- Heartbeat / unattended layer (required for ANYTHING to run on a clock) --
# Shared secret the cron jobs present to workers; must match what you pass to
# garvis_arm_heartbeat (or the Health page's Arm button).
WORKER_SECRET=
# Secret for the daily cron functions (followups, inbox-draft, reactivate, invoice-chase).
CRON_SECRET=

# -- Email outreach (Resend) --
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=      # Svix signing secret for open/click/bounce tracking
INBOUND_SECRET=             # reply-ingestion shared secret (resend-inbound)

# -- Social / video --
AYRSHARE_API_KEY=           # real social posting (social-publish)
SHOTSTACK_API_KEY=          # video rendering (render-video)

# -- Research / prospecting / scraping --
SERPER_API_KEY=             # web search for research + discovery
PERPLEXITY_API_KEY=         # Explorer topic discovery
GOOGLE_PLACES_API_KEY=      # daily client hunt + business leads
SCREENSHOT_API_KEY=         # site screenshots for audits (shot-worker)

# -- Memory (semantic recall; falls back to keyword matching without it) --
EMBEDDINGS_API_KEY=         # OpenAI-compatible embeddings key (text-embedding-3-small)

# -- Ship (deploys) --
NETLIFY_AUTH_TOKEN=         # one-click site deploys (deploy-site)
SB_MANAGEMENT_TOKEN=        # database provisioning + backend deploys

# -- Ads (read-only sync + anomaly watch) --
META_ADS_ACCESS_TOKEN=
GOOGLE_ADS_DEVELOPER_TOKEN=
